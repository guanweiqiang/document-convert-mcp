# Document Converter MCP Server Environment Variables
# Workspace directory for document conversions (default: current working directory)
DOC_CONVERTER_WORKSPACE=

# Maximum input file size in bytes (default: 52428800 = 50MB)
DOC_CONVERTER_MAX_FILE_SIZE=

# Command execution timeout in milliseconds (default: 60000 = 60s)
DOC_CONVERTER_CMD_TIMEOUT=

# Log level: debug, info, warn, error (default: info)
DOC_CONVERTER_LOG_LEVEL=
